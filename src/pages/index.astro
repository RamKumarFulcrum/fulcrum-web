---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { client } from '../lib/sanity';

const posts = await client.fetch(
  `*[_type == "post"] | order(publishedAt desc)[0...6]{
    title,
    "slug": slug.current,
    publishedAt,
    excerpt,
    "authorName": author->name,
    "categoryName": categories[0]->title
  }`
);

const siteUrl = 'https://thefulcrum.in';

const websiteSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "The Fulcrum",
  "url": siteUrl,
  "description": "Independent analysis of Indian geopolitics, foreign policy, defense, and diplomacy.",
  "publisher": {
    "@type": "Organization",
    "name": "The Fulcrum",
    "url": siteUrl
  }
});

const breadcrumbs = [{ name: "Home", url: siteUrl }];
---

<BaseLayout
  title="The Fulcrum"
  description="Independent analysis of Indian geopolitics, foreign policy, defense, and diplomacy."
  breadcrumbs={breadcrumbs}
  schemaMarkup={websiteSchema}
>
  <section class="homepage">
    <div class="hero">
      <p class="hero-kicker">Geopolitical Intelligence</p>
      <h1 class="hero-headline">The world, read from India's vantage point.</h1>
      <p class="hero-sub">Independent geopolitical intelligence for analysts, investors, and policymakers who make decisions where India matters.</p>
      <div class="hero-proof">
        <span>No opinion columns</span>
        <span class="proof-sep">·</span>
        <span>No domestic politics</span>
        <span class="proof-sep">·</span>
        <span>No Western framing</span>
      </div>
    </div>
    <div class="subscribe-inline">
      <p class="subscribe-inline-text">Weekly intelligence on India's place in the world.</p>
      <a href="https://readfulcrum.beehiiv.com/subscribe" target="_blank" class="subscribe-inline-btn">Subscribe Free →</a>
    </div>
    <header class="section-header">
      <span class="section-label">Latest Analysis</span>
      <div class="section-rule"></div>
    </header>

    {posts && posts.length > 0 ? (
      <div class="posts-list">
        {posts.map((post: any, index: number) => (
          <PostCard
            title={post.title}
            slug={post.slug}
            excerpt={post.excerpt}
            publishedAt={post.publishedAt}
            authorName={post.authorName}
            categoryName={post.categoryName}
            featured={index === 0}
          />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p>No dispatches yet.</p>
        <p class="empty-hint">Add content in Sanity Studio to see posts here.</p>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .homepage {
    max-width: 740px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: 0.5rem;
  }

  .section-label {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
    display: block;
  }

  .section-rule {
    height: 1px;
    background: var(--color-border);
  }

  .posts-list {
    display: flex;
    flex-direction: column;
  }

  .hero {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .hero-kicker {
    font-family: var(--font-ui);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .hero-headline {
    font-family: var(--font-headline);
    font-size: 2.6rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-primary);
    max-width: 560px;
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
    max-width: 580px;
    margin-bottom: 1.5rem;
  }

  .hero-proof {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .proof-sep {
    color: var(--color-border);
  }

  .empty-state {
    text-align: center;
    padding: 4rem 0;
  }

  .empty-state p {
    font-family: var(--font-headline);
    font-size: 1.3rem;
    color: var(--color-text-secondary);
  }

  .empty-hint {
    font-family: var(--font-ui) !important;
    font-size: 0.9rem !important;
    color: var(--color-text-muted) !important;
    margin-top: 0.5rem;
  }

  .subscribe-inline {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 2rem;
    background: var(--color-primary);
    border-radius: 4px;
    margin: 2rem 0;
  }

  .subscribe-inline-text {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-bg);
    font-style: italic;
    flex: 1;
  }

  .subscribe-inline-btn {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    background: var(--color-accent);
    text-decoration: none;
    padding: 0.65rem 1.5rem;
    border-radius: 2px;
    white-space: nowrap;
    transition: background 0.2s;
  }

  .subscribe-inline-btn:hover {
    background: #b8852e;
  }

  @media (max-width: 768px) {
    .subscribe-inline {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.25rem;
    }
    .hero-headline {
      font-size: 1.9rem;
    }
  }
</style>
