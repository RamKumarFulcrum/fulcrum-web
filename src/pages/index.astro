---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { client } from '../lib/sanity';

const posts = await client.fetch(
  `*[_type == "post"] | order(publishedAt desc)[0...6]{
    title,
    "slug": slug.current,
    publishedAt,
    excerpt,
    "authorName": author->name,
    "categoryName": categories[0]->title
  }`
);

const siteUrl = 'https://thefulcrum.in';

const websiteSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "The Fulcrum",
  "url": siteUrl,
  "description": "Independent analysis of Indian geopolitics, foreign policy, defense, and diplomacy.",
  "publisher": {
    "@type": "Organization",
    "name": "The Fulcrum",
    "url": siteUrl
  }
});

const breadcrumbs = [{ name: "Home", url: siteUrl }];
---

<BaseLayout
  title="The Fulcrum"
  description="Independent analysis of Indian geopolitics, foreign policy, defense, and diplomacy."
  breadcrumbs={breadcrumbs}
  schemaMarkup={websiteSchema}
>
  <section class="homepage">
    <div class="hero">
      <div class="hero-text">
        <p class="hero-kicker">Geopolitical Intelligence</p>
        <h1 class="hero-headline">The world, read from India's vantage point.</h1>
        <p class="hero-sub">Independent geopolitical intelligence for analysts, investors, and policymakers who make decisions where India matters.</p>
        <div class="hero-proof">
          <span>No opinion columns</span>
          <span class="proof-sep">·</span>
          <span>No domestic politics</span>
          <span class="proof-sep">·</span>
          <span>No Western framing</span>
        </div>
      </div>

      <div class="hero-sidebar">
        <div class="hero-sidebar-posts">
          <p class="hero-sidebar-label">Latest Analysis</p>
          {posts && posts.length > 0 && (
            <ul class="hero-sidebar-list">
              {posts.slice(0, 3).map((post: any) => (
                <li>
                  <a href={`/blog/${post.slug}`} class="hero-sidebar-link">{post.title}</a>
                </li>
              ))}
            </ul>
          )}
        </div>
        <div class="hero-sidebar-subscribe">
          <p class="hero-sidebar-subscribe-title">The Fulcrum Brief</p>
          <p class="hero-sidebar-subscribe-text">Weekly intelligence on India's strategic position in the world. Free.</p>
          <a href="https://readfulcrum.beehiiv.com/subscribe" target="_blank" class="hero-sidebar-subscribe-btn">Subscribe →</a>
        </div>
      </div>
    </div>

    <header class="section-header">
      <span class="section-label">Latest Analysis</span>
      <div class="section-rule"></div>
    </header>

    {posts && posts.length > 0 ? (
      <div class="posts-list">
        {posts.map((post: any, index: number) => (
          <PostCard
            title={post.title}
            slug={post.slug}
            excerpt={post.excerpt}
            publishedAt={post.publishedAt}
            authorName={post.authorName}
            categoryName={post.categoryName}
            featured={index === 0}
          />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p>No dispatches yet.</p>
        <p class="empty-hint">Add content in Sanity Studio to see posts here.</p>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .homepage {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* ---- Hero two-column grid ---- */
  .hero {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 4rem;
    align-items: center;
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .hero-text {
    min-width: 0;
  }

  .hero-kicker {
    font-family: var(--font-ui);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .hero-headline {
    font-family: var(--font-headline);
    font-size: 2.6rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-primary);
    max-width: 560px;
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
    max-width: 580px;
    margin-bottom: 1.5rem;
  }

  .hero-proof {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .proof-sep {
    color: var(--color-border);
  }

  /* ---- Hero sidebar (right column) ---- */
  .hero-sidebar {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hero-sidebar-posts {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 4px 4px 0 0;
    padding: 1.5rem;
  }

  .hero-sidebar-label {
    font-family: var(--font-ui);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .hero-sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hero-sidebar-list li {
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem 0;
  }

  .hero-sidebar-list li:first-child {
    padding-top: 0;
  }

  .hero-sidebar-list li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .hero-sidebar-link {
    font-family: var(--font-headline);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
    line-height: 1.35;
    display: block;
    transition: color 0.15s;
  }

  .hero-sidebar-link:hover {
    color: var(--color-accent);
  }

  /* ---- Hero subscribe box ---- */
  .hero-sidebar-subscribe {
    background: var(--color-primary);
    color: var(--color-white);
    padding: 1.5rem;
    border-radius: 0 0 4px 4px;
  }

  .hero-sidebar-subscribe-title {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.6rem;
  }

  .hero-sidebar-subscribe-text {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: #ccc;
    line-height: 1.6;
    font-style: italic;
    margin-bottom: 1rem;
  }

  .hero-sidebar-subscribe-btn {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    background: var(--color-accent);
    text-decoration: none;
    padding: 0.6rem 1.25rem;
    border-radius: 2px;
    transition: background 0.2s;
  }

  .hero-sidebar-subscribe-btn:hover {
    background: #b8852e;
  }

  /* ---- Below hero ---- */
  .section-header {
    margin-bottom: 0.5rem;
    max-width: 740px;
  }

  .section-label {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
    display: block;
  }

  .section-rule {
    height: 1px;
    background: var(--color-border);
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    max-width: 740px;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 0;
  }

  .empty-state p {
    font-family: var(--font-headline);
    font-size: 1.3rem;
    color: var(--color-text-secondary);
  }

  .empty-hint {
    font-family: var(--font-ui) !important;
    font-size: 0.9rem !important;
    color: var(--color-text-muted) !important;
    margin-top: 0.5rem;
  }

  /* ---- Mobile ---- */
  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .hero-headline {
      font-size: 1.9rem;
    }
  }
</style>
