---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { client } from '../lib/sanity';

const posts = await client.fetch(
  `*[_type == "post"] | order(publishedAt desc)[0...6]{
    title,
    "slug": slug.current,
    publishedAt,
    excerpt,
    "authorName": author->name,
    "categoryName": categories[0]->title
  }`
);

const siteUrl = 'https://thefulcrum.in';

const websiteSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "The Fulcrum",
  "url": siteUrl,
  "description": "Independent analysis of Indian geopolitics, foreign policy, defense, and diplomacy.",
  "publisher": {
    "@type": "Organization",
    "name": "The Fulcrum",
    "url": siteUrl
  }
});

const breadcrumbs = [{ name: "Home", url: siteUrl }];
---

<BaseLayout
  title="The Fulcrum"
  description="Independent analysis of Indian geopolitics, foreign policy, defense, and diplomacy."
  breadcrumbs={breadcrumbs}
  schemaMarkup={websiteSchema}
>
  <section class="homepage">
    <div class="hero">
      <div class="hero-text">
        <p class="hero-kicker">Geopolitical Intelligence</p>
        <h1 class="hero-headline">The world, read from India's vantage point.</h1>
        <p class="hero-sub">Independent geopolitical intelligence for analysts, investors, and policymakers who make decisions where India matters.</p>
        <div class="hero-proof">
          <span>No opinion columns</span>
          <span class="proof-sep">·</span>
          <span>No domestic politics</span>
          <span class="proof-sep">·</span>
          <span>No Western framing</span>
        </div>
      </div>
      <div class="hero-illustration">
        <svg viewBox="0 0 340 400" xmlns="http://www.w3.org/2000/svg" class="chess-svg">
          <!-- Outer frame -->
          <rect x="0" y="0" width="340" height="400" fill="#F5F0E8" rx="3"/>
          <!-- Gold top rule -->
          <rect x="0" y="0" width="340" height="4" fill="#B8960A" rx="3 3 0 0"/>
          <!-- Double border -->
          <rect x="8" y="12" width="324" height="376" fill="none" stroke="#D4C4A0" stroke-width="1" rx="2"/>
          <rect x="12" y="16" width="316" height="368" fill="none" stroke="#D4C4A0" stroke-width="0.5" rx="1"/>

          <!-- Board area offset -->
          <g transform="translate(46, 32)">
            <!-- Column labels top -->
            <text x="16" y="8" font-family="'DM Sans', sans-serif" font-size="7" fill="#888" text-anchor="middle">a</text>
            <text x="47" y="8" font-family="'DM Sans', sans-serif" font-size="7" fill="#888" text-anchor="middle">b</text>
            <text x="78" y="8" font-family="'DM Sans', sans-serif" font-size="7" fill="#888" text-anchor="middle">c</text>
            <text x="109" y="8" font-family="'DM Sans', sans-serif" font-size="7" fill="#888" text-anchor="middle">d</text>
            <text x="140" y="8" font-family="'DM Sans', sans-serif" font-size="7" fill="#888" text-anchor="middle">e</text>
            <text x="171" y="8" font-family="'DM Sans', sans-serif" font-size="7" fill="#888" text-anchor="middle">f</text>
            <text x="202" y="8" font-family="'DM Sans', sans-serif" font-size="7" fill="#888" text-anchor="middle">g</text>
            <text x="233" y="8" font-family="'DM Sans', sans-serif" font-size="7" fill="#888" text-anchor="middle">h</text>

            <!-- Board squares 8x8, each 31px -->
            <g transform="translate(0, 14)">
              <!-- Row 8 -->
              <rect x="0" y="0" width="31" height="31" fill="#D4C4A0"/><rect x="31" y="0" width="31" height="31" fill="#1a1a1a"/><rect x="62" y="0" width="31" height="31" fill="#D4C4A0"/><rect x="93" y="0" width="31" height="31" fill="#1a1a1a"/><rect x="124" y="0" width="31" height="31" fill="#D4C4A0"/><rect x="155" y="0" width="31" height="31" fill="#1a1a1a"/><rect x="186" y="0" width="31" height="31" fill="#D4C4A0"/><rect x="217" y="0" width="31" height="31" fill="#1a1a1a"/>
              <!-- Row 7 -->
              <rect x="0" y="31" width="31" height="31" fill="#1a1a1a"/><rect x="31" y="31" width="31" height="31" fill="#D4C4A0"/><rect x="62" y="31" width="31" height="31" fill="#1a1a1a"/><rect x="93" y="31" width="31" height="31" fill="#D4C4A0"/><rect x="124" y="31" width="31" height="31" fill="#1a1a1a"/><rect x="155" y="31" width="31" height="31" fill="#D4C4A0"/><rect x="186" y="31" width="31" height="31" fill="#1a1a1a"/><rect x="217" y="31" width="31" height="31" fill="#D4C4A0"/>
              <!-- Row 6 -->
              <rect x="0" y="62" width="31" height="31" fill="#D4C4A0"/><rect x="31" y="62" width="31" height="31" fill="#1a1a1a"/><rect x="62" y="62" width="31" height="31" fill="#D4C4A0"/><rect x="93" y="62" width="31" height="31" fill="#1a1a1a"/><rect x="124" y="62" width="31" height="31" fill="#D4C4A0"/><rect x="155" y="62" width="31" height="31" fill="#1a1a1a"/><rect x="186" y="62" width="31" height="31" fill="#D4C4A0"/><rect x="217" y="62" width="31" height="31" fill="#1a1a1a"/>
              <!-- Row 5 -->
              <rect x="0" y="93" width="31" height="31" fill="#1a1a1a"/><rect x="31" y="93" width="31" height="31" fill="#D4C4A0"/><rect x="62" y="93" width="31" height="31" fill="#1a1a1a"/><rect x="93" y="93" width="31" height="31" fill="#D4C4A0"/><rect x="124" y="93" width="31" height="31" fill="#1a1a1a"/><rect x="155" y="93" width="31" height="31" fill="#D4C4A0"/><rect x="186" y="93" width="31" height="31" fill="#1a1a1a"/><rect x="217" y="93" width="31" height="31" fill="#D4C4A0"/>
              <!-- Row 4 -->
              <rect x="0" y="124" width="31" height="31" fill="#D4C4A0"/><rect x="31" y="124" width="31" height="31" fill="#1a1a1a"/><rect x="62" y="124" width="31" height="31" fill="#D4C4A0"/><rect x="93" y="124" width="31" height="31" fill="#1a1a1a"/><rect x="124" y="124" width="31" height="31" fill="#D4C4A0"/><rect x="155" y="124" width="31" height="31" fill="#1a1a1a"/><rect x="186" y="124" width="31" height="31" fill="#D4C4A0"/><rect x="217" y="124" width="31" height="31" fill="#1a1a1a"/>
              <!-- Row 3 -->
              <rect x="0" y="155" width="31" height="31" fill="#1a1a1a"/><rect x="31" y="155" width="31" height="31" fill="#D4C4A0"/><rect x="62" y="155" width="31" height="31" fill="#1a1a1a"/><rect x="93" y="155" width="31" height="31" fill="#D4C4A0"/><rect x="124" y="155" width="31" height="31" fill="#1a1a1a"/><rect x="155" y="155" width="31" height="31" fill="#D4C4A0"/><rect x="186" y="155" width="31" height="31" fill="#1a1a1a"/><rect x="217" y="155" width="31" height="31" fill="#D4C4A0"/>
              <!-- Row 2 -->
              <rect x="0" y="186" width="31" height="31" fill="#D4C4A0"/><rect x="31" y="186" width="31" height="31" fill="#1a1a1a"/><rect x="62" y="186" width="31" height="31" fill="#D4C4A0"/><rect x="93" y="186" width="31" height="31" fill="#1a1a1a"/><rect x="124" y="186" width="31" height="31" fill="#D4C4A0"/><rect x="155" y="186" width="31" height="31" fill="#1a1a1a"/><rect x="186" y="186" width="31" height="31" fill="#D4C4A0"/><rect x="217" y="186" width="31" height="31" fill="#1a1a1a"/>
              <!-- Row 1 -->
              <rect x="0" y="217" width="31" height="31" fill="#1a1a1a"/><rect x="31" y="217" width="31" height="31" fill="#D4C4A0"/><rect x="62" y="217" width="31" height="31" fill="#1a1a1a"/><rect x="93" y="217" width="31" height="31" fill="#D4C4A0"/><rect x="124" y="217" width="31" height="31" fill="#1a1a1a"/><rect x="155" y="217" width="31" height="31" fill="#D4C4A0"/><rect x="186" y="217" width="31" height="31" fill="#1a1a1a"/><rect x="217" y="217" width="31" height="31" fill="#D4C4A0"/>

              <!-- Row labels (right side) -->
              <text x="256" y="20" font-family="'DM Sans', sans-serif" font-size="7" fill="#888" text-anchor="middle">8</text>
              <text x="256" y="51" font-family="'DM Sans', sans-serif" font-size="7" fill="#888" text-anchor="middle">7</text>
              <text x="256" y="82" font-family="'DM Sans', sans-serif" font-size="7" fill="#888" text-anchor="middle">6</text>
              <text x="256" y="113" font-family="'DM Sans', sans-serif" font-size="7" fill="#888" text-anchor="middle">5</text>
              <text x="256" y="144" font-family="'DM Sans', sans-serif" font-size="7" fill="#888" text-anchor="middle">4</text>
              <text x="256" y="175" font-family="'DM Sans', sans-serif" font-size="7" fill="#888" text-anchor="middle">3</text>
              <text x="256" y="206" font-family="'DM Sans', sans-serif" font-size="7" fill="#888" text-anchor="middle">2</text>
              <text x="256" y="237" font-family="'DM Sans', sans-serif" font-size="7" fill="#888" text-anchor="middle">1</text>

              <!-- DARK PIECES (opposing powers) - Row 8 back rank -->
              <!-- Rook a8 -->
              <text x="15.5" y="22" font-size="20" text-anchor="middle" fill="#444">♜</text>
              <!-- Knight b8 -->
              <text x="46.5" y="22" font-size="20" text-anchor="middle" fill="#444">♞</text>
              <!-- Bishop c8 -->
              <text x="77.5" y="22" font-size="20" text-anchor="middle" fill="#444">♝</text>
              <!-- Queen d8 -->
              <text x="108.5" y="22" font-size="20" text-anchor="middle" fill="#444">♛</text>
              <!-- King e8 -->
              <text x="139.5" y="22" font-size="20" text-anchor="middle" fill="#444">♚</text>
              <!-- Bishop f8 -->
              <text x="170.5" y="22" font-size="20" text-anchor="middle" fill="#444">♝</text>
              <!-- Knight g8 -->
              <text x="201.5" y="22" font-size="20" text-anchor="middle" fill="#444">♞</text>
              <!-- Rook h8 -->
              <text x="232.5" y="22" font-size="20" text-anchor="middle" fill="#444">♜</text>

              <!-- Dark pawns Row 7 -->
              <text x="15.5" y="53" font-size="16" text-anchor="middle" fill="#444">♟</text>
              <text x="46.5" y="53" font-size="16" text-anchor="middle" fill="#444">♟</text>
              <text x="77.5" y="53" font-size="16" text-anchor="middle" fill="#444">♟</text>
              <!-- d7 pawn moved to d5 -->
              <text x="139.5" y="53" font-size="16" text-anchor="middle" fill="#444">♟</text>
              <text x="170.5" y="53" font-size="16" text-anchor="middle" fill="#444">♟</text>
              <text x="201.5" y="53" font-size="16" text-anchor="middle" fill="#444">♟</text>
              <text x="232.5" y="53" font-size="16" text-anchor="middle" fill="#444">♟</text>
              <!-- Dark pawn d5 (advanced) -->
              <text x="108.5" y="115" font-size="16" text-anchor="middle" fill="#444">♟</text>
              <!-- Dark knight developed to f6 -->
              <text x="170.5" y="84" font-size="20" text-anchor="middle" fill="#444">♞</text>

              <!-- GOLD PIECES (India's side) - Row 1 back rank -->
              <!-- Rook a1 -->
              <text x="15.5" y="239" font-size="20" text-anchor="middle" fill="#B8960A">♜</text>
              <!-- Knight b1 -->
              <text x="46.5" y="239" font-size="20" text-anchor="middle" fill="#B8960A">♞</text>
              <!-- Bishop c1 -->
              <text x="77.5" y="239" font-size="20" text-anchor="middle" fill="#B8960A">♝</text>
              <!-- Queen d1 -->
              <text x="108.5" y="239" font-size="20" text-anchor="middle" fill="#B8960A">♛</text>
              <!-- King e1 -->
              <text x="139.5" y="239" font-size="20" text-anchor="middle" fill="#B8960A">♚</text>
              <!-- Bishop f1 -->
              <text x="170.5" y="239" font-size="20" text-anchor="middle" fill="#B8960A">♝</text>
              <!-- Rook h1 -->
              <text x="232.5" y="239" font-size="20" text-anchor="middle" fill="#B8960A">♜</text>

              <!-- Gold pawns Row 2 -->
              <text x="15.5" y="208" font-size="16" text-anchor="middle" fill="#B8960A">♟</text>
              <text x="46.5" y="208" font-size="16" text-anchor="middle" fill="#B8960A">♟</text>
              <text x="77.5" y="208" font-size="16" text-anchor="middle" fill="#B8960A">♟</text>
              <text x="139.5" y="208" font-size="16" text-anchor="middle" fill="#B8960A">♟</text>
              <text x="170.5" y="208" font-size="16" text-anchor="middle" fill="#B8960A">♟</text>
              <text x="201.5" y="208" font-size="16" text-anchor="middle" fill="#B8960A">♟</text>
              <text x="232.5" y="208" font-size="16" text-anchor="middle" fill="#B8960A">♟</text>
              <!-- Gold pawn d4 (advanced) -->
              <text x="108.5" y="146" font-size="16" text-anchor="middle" fill="#B8960A">♟</text>
              <!-- Gold knight developed to f3 -->
              <text x="170.5" y="177" font-size="20" text-anchor="middle" fill="#B8960A">♞</text>

              <!-- Gold dots showing possible moves -->
              <circle cx="108.5" cy="78" r="3" fill="#B8960A" opacity="0.5"/>
              <circle cx="108.5" cy="100" r="3" fill="#B8960A" opacity="0.5"/>
              <circle cx="139.5" cy="131" r="3" fill="#B8960A" opacity="0.4"/>
              <circle cx="77.5" cy="131" r="3" fill="#B8960A" opacity="0.4"/>
              <circle cx="201.5" cy="162" r="3" fill="#B8960A" opacity="0.4"/>
              <circle cx="139.5" cy="162" r="3" fill="#B8960A" opacity="0.4"/>
            </g>
          </g>

          <!-- Bottom text -->
          <text x="170" y="378" font-family="'DM Sans', sans-serif" font-size="7.5" font-weight="600" fill="#B8960A" text-anchor="middle" letter-spacing="0.25em">EVERY MOVE HAS A CONSEQUENCE</text>
        </svg>
      </div>
    </div>
    <div class="subscribe-inline">
      <p class="subscribe-inline-text">Weekly intelligence on India's place in the world.</p>
      <a href="https://readfulcrum.beehiiv.com/subscribe" target="_blank" class="subscribe-inline-btn">Subscribe Free →</a>
    </div>
    <header class="section-header">
      <span class="section-label">Latest Analysis</span>
      <div class="section-rule"></div>
    </header>

    {posts && posts.length > 0 ? (
      <div class="posts-list">
        {posts.map((post: any, index: number) => (
          <PostCard
            title={post.title}
            slug={post.slug}
            excerpt={post.excerpt}
            publishedAt={post.publishedAt}
            authorName={post.authorName}
            categoryName={post.categoryName}
            featured={index === 0}
          />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p>No dispatches yet.</p>
        <p class="empty-hint">Add content in Sanity Studio to see posts here.</p>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .homepage {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: 0.5rem;
    max-width: 740px;
  }

  .section-label {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
    display: block;
  }

  .section-rule {
    height: 1px;
    background: var(--color-border);
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    max-width: 740px;
  }

  .hero {
    display: flex;
    align-items: center;
    gap: 3rem;
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .hero-text {
    flex: 1;
    min-width: 0;
  }

  .hero-illustration {
    width: 45%;
    max-width: 380px;
    flex-shrink: 0;
  }

  .chess-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero-kicker {
    font-family: var(--font-ui);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .hero-headline {
    font-family: var(--font-headline);
    font-size: 2.6rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-primary);
    max-width: 560px;
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
    max-width: 580px;
    margin-bottom: 1.5rem;
  }

  .hero-proof {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .proof-sep {
    color: var(--color-border);
  }

  .empty-state {
    text-align: center;
    padding: 4rem 0;
  }

  .empty-state p {
    font-family: var(--font-headline);
    font-size: 1.3rem;
    color: var(--color-text-secondary);
  }

  .empty-hint {
    font-family: var(--font-ui) !important;
    font-size: 0.9rem !important;
    color: var(--color-text-muted) !important;
    margin-top: 0.5rem;
  }

  .subscribe-inline {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 2rem;
    background: var(--color-primary);
    border-radius: 4px;
    margin: 2rem 0;
    max-width: 740px;
  }

  .subscribe-inline-text {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-bg);
    font-style: italic;
    flex: 1;
  }

  .subscribe-inline-btn {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    background: var(--color-accent);
    text-decoration: none;
    padding: 0.65rem 1.5rem;
    border-radius: 2px;
    white-space: nowrap;
    transition: background 0.2s;
  }

  .subscribe-inline-btn:hover {
    background: #b8852e;
  }

  @media (max-width: 768px) {
    .hero {
      flex-direction: column;
    }

    .hero-illustration {
      width: 80%;
      max-width: 300px;
      margin: 0 auto;
    }

    .subscribe-inline {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.25rem;
    }

    .hero-headline {
      font-size: 1.9rem;
    }
  }

  @media (max-width: 480px) {
    .hero-illustration {
      width: 100%;
    }
  }
</style>
